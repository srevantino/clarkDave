<?xml version="1.0" encoding="utf-8"?>
<!--
    ╔══════════════════════════════════════════════════════════════════╗
    ║   Advanced Systems — Unattended Windows Install                  ║
    ║   autounattend.xml  |  VERSION: 0.1 TEST PHASE                   ║
    ║   Compatible: Windows 10 & 11  |  Home / Home SL / Pro          ║
    ╚══════════════════════════════════════════════════════════════════╝

    USER INTERACTION:
      1. Ventoy boot menu  → user picks Win10 or Win11 ISO
      2. Product key screen → user clicks "I don't have a product key"
      3. Edition picker     → user picks Home / Home SL / Pro
      4. Everything after   → fully automated

    ACCOUNTS CREATED:
      • TECH  (Administrator, password: 12)  — Advanced Systems admin
      • User  (Administrator) — main account; name from Clark build dialog
        └─ Permanent member of the local Administrators group.

    NOTES:
      • Win 11 hardware bypasses (TPM, SecureBoot, RAM, CPU, Storage)
        are injected during windowsPE pass — works on any hardware.
      • Language/region/timezone are set to en-US / UTC as defaults.
        Update <UserLocale>, <InputLocale>, <TimeZone> before final build.
      • Computer name defaults to ASYS-PC. Update when client name is known.
-->
<unattend xmlns="urn:schemas-microsoft-com:unattend"
          xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">


  <!-- ═══════════════════════════════════════════════════════════════
       PASS 1 — windowsPE
       Runs inside Windows PE before installation begins.
       Handles: hardware bypasses, disk layout, image selection.
       ═══════════════════════════════════════════════════════════════ -->
  <settings pass="windowsPE">

    <!-- Setup UI language and keyboard layout -->
    <component name="Microsoft-Windows-International-Core-WinPE"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <SetupUILanguage>
        <UILanguage>en-US</UILanguage>
        <WillShowUI>Never</WillShowUI>
      </SetupUILanguage>
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UILanguageFallback>en-US</UILanguageFallback>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">

      <!-- ── Hardware Requirement Bypasses (Win 11) ──────────────────
           These registry keys are injected into the PE hive before
           hardware checks run. Identical to what Rufus/Clark inject.
           Safe to include in Win 10 ISOs — keys are simply ignored.
      ─────────────────────────────────────────────────────────────── -->
      <!-- Hardware Requirement Bypasses (Win 11 — ignored on Win 10) -->
      <RunSynchronous>
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\LabConfig" /v BypassTPMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\LabConfig" /v BypassSecureBootCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>3</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\LabConfig" /v BypassRAMCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>4</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\LabConfig" /v BypassCPUCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>5</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\LabConfig" /v BypassStorageCheck /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>6</Order>
          <Path>reg add "HKLM\SYSTEM\Setup\MoSetup" /v AllowUpgradesWithUnsupportedTPMOrCPU /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
        <RunSynchronousCommand wcm:action="add">
          <Order>7</Order>
          <Path>reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\OOBE" /v BypassNRO /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
      </RunSynchronous>

      <!-- Skip product key screen — client activates on-site -->
      <UserData>
        <AcceptEula>true</AcceptEula>
        <FullName>User</FullName>
        <Organization>Advanced Systems</Organization>
        <ProductKey>
          <Key></Key>
          <WillShowUI>Never</WillShowUI>
        </ProductKey>
      </UserData>

      <!-- Disk layout: UEFI / GPT (use autounattend-legacy.xml for Legacy BIOS / MBR). -->
      <DiskConfiguration>
        <WillShowUI>OnError</WillShowUI>
        <Disk wcm:action="add">
          <DiskID>0</DiskID>
          <WillWipeDisk>true</WillWipeDisk>
          <CreatePartitions>
            <CreatePartition wcm:action="add">
              <Order>1</Order>
              <Type>EFI</Type>
              <Size>300</Size>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>2</Order>
              <Type>MSR</Type>
              <Size>16</Size>
            </CreatePartition>
            <CreatePartition wcm:action="add">
              <Order>3</Order>
              <Type>Primary</Type>
              <Extend>true</Extend>
            </CreatePartition>
          </CreatePartitions>
          <ModifyPartitions>
            <ModifyPartition wcm:action="add">
              <Order>1</Order>
              <PartitionID>1</PartitionID>
              <Label>System</Label>
              <Format>FAT32</Format>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>2</Order>
              <PartitionID>2</PartitionID>
            </ModifyPartition>
            <ModifyPartition wcm:action="add">
              <Order>3</Order>
              <PartitionID>3</PartitionID>
              <Label>Windows</Label>
              <Format>NTFS</Format>
              <Letter>C</Letter>
            </ModifyPartition>
          </ModifyPartitions>
        </Disk>
      </DiskConfiguration>

      <ImageInstall>
        <OSImage>
          <InstallTo>
            <DiskID>0</DiskID>
            <PartitionID>3</PartitionID>
          </InstallTo>
          <InstallToAvailablePartition>false</InstallToAvailablePartition>
        </OSImage>
      </ImageInstall>

    </component>
  </settings>


  <!-- ═══════════════════════════════════════════════════════════════
       PASS 2 — specialize
       Runs after install, before OOBE. System has a HAL at this point.
       Handles: computer name, timezone, activation skip.
       ═══════════════════════════════════════════════════════════════ -->
  <settings pass="specialize">

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <!-- Placeholder %%COMPUTERNAME%% replaced by Clark pre-build dialog.
           DNS (10.1.1.11 / 10.160.5.7) applied by master.ps1 Phase 0. -->
      <ComputerName>%%COMPUTERNAME%%</ComputerName>
      <TimeZone>Singapore Standard Time</TimeZone>
    </component>

    <!-- Skip Windows activation prompt at startup -->
    <component name="Microsoft-Windows-Security-SPP-UX"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <SkipAutoActivation>true</SkipAutoActivation>
    </component>

  </settings>


  <!-- ═══════════════════════════════════════════════════════════════
       PASS 3 — oobeSystem
       Runs during and after OOBE (first-boot experience).
       Handles: skip all OOBE screens, create accounts, launch master.ps1.
       ═══════════════════════════════════════════════════════════════ -->
  <settings pass="oobeSystem">

    <!-- en-US for all locale settings — Malaysia region applied by master.ps1 Phase 0 -->
    <component name="Microsoft-Windows-International-Core"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UILanguageFallback>en-US</UILanguageFallback>
      <UserLocale>en-US</UserLocale>
    </component>

    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS">

      <!-- ── Skip All OOBE Screens ─────────────────────────────────── -->
      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <SkipMachineOOBE>true</SkipMachineOOBE>
        <SkipUserOOBE>true</SkipUserOOBE>
        <!-- 3 = Do not set up automatic protection. Disables the
             "Choose privacy settings" and protection prompts. -->
        <ProtectYourPC>3</ProtectYourPC>
      </OOBE>

      <!-- ── User Accounts ─────────────────────────────────────────────
           TECH  — Advanced Systems hidden admin account (pw: 12)
           User  — Main user account (no password, admin during setup)
                   Placeholder %%USERNAME%% is replaced by Clark pre-build dialog.
      ─────────────────────────────────────────────────────────────── -->
      <UserAccounts>
        <LocalAccounts>

          <!-- TECH admin account — for Advanced Systems use -->
          <LocalAccount wcm:action="add">
            <Name>TECH</Name>
            <DisplayName>TECH</DisplayName>
            <Description>Administrator</Description>
            <Group>Administrators</Group>
            <Password>
              <Value>MQAyAFAAYQBzAHMAdwBvAHIAZAA=</Value>
              <PlainText>false</PlainText>
            </Password>
          </LocalAccount>

          <!-- Main user account — permanent local Administrator -->
          <LocalAccount wcm:action="add">
            <Name>%%USERNAME%%</Name>
            <DisplayName>%%USERNAME%%</DisplayName>
            <Description>Main User Account (Administrator)</Description>
            <Group>Administrators</Group>
            <Password>
              <Value>MQ==</Value>
              <PlainText>false</PlainText>
            </Password>
          </LocalAccount>

        </LocalAccounts>
      </UserAccounts>

      <Groups>
        <LocalGroup wcm:action="add">
          <GroupName>Administrators</GroupName>
          <Members>
            <Member wcm:action="add">
              <Name>%%USERNAME%%</Name>
            </Member>
          </Members>
        </LocalGroup>
      </Groups>

      <!-- ── Auto Login ─────────────────────────────────────────────────
           Logs in as User automatically once on first boot.
           LogonCount=1 means after master.ps1 finishes (or reboots),
           normal login behaviour resumes.
      ─────────────────────────────────────────────────────────────── -->
      <AutoLogon>
        <Enabled>true</Enabled>
        <Username>%%USERNAME%%</Username>
        <LogonCount>99</LogonCount>
        <Password>
          <Value>MQ==</Value>
          <PlainText>false</PlainText>
        </Password>
      </AutoLogon>

      <!-- ── First Logon Commands ───────────────────────────────────────
           Fires master.ps1 the moment User's desktop loads.
           master.ps1 then registers itself in Task Scheduler so it
           survives all subsequent reboots through the phase system.
      ─────────────────────────────────────────────────────────────── -->
      <FirstLogonCommands>
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Description>Ensure main user is in Administrators</Description>
          <CommandLine>cmd /c net localgroup Administrators "%%USERNAME%%" /add</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>2</Order>
          <CommandLine>powershell.exe -WindowStyle Hidden -ExecutionPolicy Bypass -File "C:\Setup\master.ps1"</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>
      </FirstLogonCommands>

    </component>
  </settings>

</unattend>
